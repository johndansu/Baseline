{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build:prod",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/v1/:path*",
      "destination": "/api/proxy/v1/:path*"
    },
    {
      "source": "/healthz",
      "destination": "/api/proxy/healthz"
    },
    {
      "source": "/readyz",
      "destination": "/api/proxy/readyz"
    },
    {
      "source": "/livez",
      "destination": "/api/proxy/livez"
    },
    {
      "source": "/metrics",
      "destination": "/api/proxy/metrics"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/signin",
      "destination": "/signin.html"
    },
    {
      "source": "/signup",
      "destination": "/signup.html"
    },
    {
      "source": "/cli-login",
      "destination": "/cli-login.html"
    },
    {
      "source": "/cli-guide",
      "destination": "/cli-guide.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/(.*)\\.(js|css)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
